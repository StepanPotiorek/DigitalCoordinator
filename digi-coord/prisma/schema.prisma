generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  name         String?
  email        String    @unique
  passwordHash String
  role         Role      @default(COORDINATOR)
  company      Company?
  notifications Notification[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

enum Role {
  ADMIN
  COORDINATOR
  COMPANY
  WORKER
}

model Worker {
  id                   Int               @id @default(autoincrement())
  name                 String
  whatsapp             String
  email                String?  @unique
  employer             String?
  accommodation        String?
  arrivalDate          DateTime?
  emergencyContactName String?
  emergencyContactPhone String?
  status               WorkerStatus          @default(PENDING_APPROVAL)
  onboardingStatus     OnboardingStatus      @default(PENDING)
  employeeCardStatus   EmployeeCardStatus    @default(NOT_STARTED)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  accommodationDetail Accommodation?
  onboardingItems     OnboardingItem[]
  issues              Issue[]
  communications     CommunicationLog[]
  documents           Document[]
  situationFeedback   SituationFeedback[]
  notes               Note[]

  @@index([employer])
  @@index([status])
  @@index([onboardingStatus])
  @@index([createdAt])
}

enum WorkerStatus {
  PENDING_APPROVAL
  ACTIVE
  REJECTED
}

enum OnboardingStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum EmployeeCardStatus {
  NOT_STARTED
  IN_PROGRESS
  BIOMETRICS_DONE
  CARD_READY
  ISSUED
}

model OnboardingItem {
  id          Int                @id @default(autoincrement())
  workerId    Int
  label       String
  category    OnboardingCategory
  completed   Boolean            @default(false)
  completedAt DateTime?
  createdAt   DateTime           @default(now())

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId])
  @@index([category])
  @@index([completed])
}

enum OnboardingCategory {
  BEFORE_ARRIVAL
  AFTER_ARRIVAL
  FIRST_DAY
  SIM_CARD
  BANK_ACCOUNT
  ACCOMMODATION
  EMERGENCY
  LANGUAGE
  ADAPTATION
  IMMIGRATION
}

model Issue {
  id          Int           @id @default(autoincrement())
  workerId    Int?
  issueType   String
  description String
  priority    IssuePriority @default(MEDIUM)
  status      IssueStatus   @default(OPEN)
  mediaUrls   String        @default("[]")
  situationId String?
  contacted   String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  worker Worker? @relation(fields: [workerId], references: [id], onDelete: SetNull)

  @@index([workerId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@index([situationId])
}

model SituationFeedback {
  id          Int      @id @default(autoincrement())
  workerId    Int
  situationId String
  helped      Boolean
  contacted   String?
  createdAt   DateTime @default(now())

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId])
  @@index([helped])
  @@index([situationId])
}

enum IssuePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

model Accommodation {
  id           Int      @id @default(autoincrement())
  workerId     Int      @unique
  address      String
  room         String?
  rules        String?
  contactName  String?
  contactPhone String?
  mapUrl       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId])
}

model Company {
  id           Int      @id @default(autoincrement())
  name         String
  contactEmail String?
  contactPhone String?
  notes        String?
  userId       String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user           User?              @relation(fields: [userId], references: [id])
  communications CommunicationLog[]

  @@index([name])
}

model CommunicationLog {
  id        Int               @id @default(autoincrement())
  workerId  Int
  companyId Int?
  type      CommunicationType
  message   String
  createdBy String
  createdAt DateTime          @default(now())

  worker Worker  @relation(fields: [workerId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([workerId])
  @@index([companyId])
  @@index([createdAt])
}

enum CommunicationType {
  NOTE
  ISSUE_UPDATE
  ONBOARDING_UPDATE
  GENERAL
}

model Faq {
  id        Int      @id @default(autoincrement())
  question  String
  answer    String
  category  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([order])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  used      Boolean  @default(false)

  @@index([email])
  @@index([token])
}

model Notification {
  id        Int      @id @default(autoincrement())
  type      String
  title     String   @default("")
  message   String
  link      String?
  read      Boolean  @default(false)
  userId    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([read])
  @@index([createdAt])
  @@index([userId])
}

model PushSubscription {
  id            Int      @id @default(autoincrement())
  endpoint      String   @unique
  p256dh        String
  auth          String
  userAgent     String?
  subscribedAt  DateTime @default(now())

  @@index([endpoint])
}

model Document {
  id           Int      @id @default(autoincrement())
  workerId     Int
  type         DocumentType
  filename     String
  originalName String
  uploadedAt   DateTime @default(now())

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    String?
  action    String
  entity    String
  entityId  Int?
  details   String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([entity])
  @@index([action])
  @@index([userId])
}

model Note {
  id        Int      @id @default(autoincrement())
  workerId  Int
  content   String
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId])
  @@index([createdAt])
}

model ApiKey {
  id          Int      @id @default(autoincrement())
  name        String
  keyHash     String   @unique
  scopes      String   @default("read")
  active      Boolean  @default(true)
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([keyHash])
  @@index([active])
}

enum DocumentType {
  PASSPORT
  VISA
  CONTRACT
  OTHER
}
